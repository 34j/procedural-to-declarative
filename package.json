{
  "name": "procedural-to-declarative",
  "type": "commonjs",
  "version": "1.1.0",
  "description": "Compile procedural state transitions (do, wait, set, wait, ...) into declarative time-to-state functions (t -> do, set).",
  "author": {
    "name": "34j"
  },
  "license": "MIT",
  "homepage": "https://github.com/34j/procedural-to-declarative",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/34j/procedural-to-declarative.git"
  },
  "bugs": {
    "url": "https://github.com/34j/procedural-to-declarative/issues"
  },
  "keywords": [
    "boilerplate",
    "template",
    "typescript",
    "vitest",
    "pre-commit",
    "semantic-release",
    "typedoc"
  ],
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src/**/*"
  ],
  "scripts": {
    "build:watch": "tsc --watch --project tsconfig.json",
    "preinstall": "npx only-allow pnpm",
    "build": "tsc --project tsconfig.json",
    "lint": "eslint --fix",
    "typedoc": "typedoc",
    "typedoc:watch": "typedoc --watch",
    "test:watch": "vitest --watch --coverage --coverage.include=src",
    "test": "vitest --coverage --coverage.include=src --silent=false",
    "test:run": "vitest run --coverage --coverage.include=src --silent=false --no-color",
    "watch": "npm-run-all --race --parallel *:watch",
    "readme": "runmd README.md -o README.md --no-footer",
    "doccmd": "doccmd -l ts -c 'npx tsx' --temporary-file-extension .mts  README.md",
    "update": "npm-check-updates -u",
    "semantic-release": "semantic-release"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@types/node": "25.9.1",
    "@typescript-eslint/eslint-plugin": "8.60.0",
    "@vitest/browser": "4.1.7",
    "@vitest/browser-playwright": "4.1.7",
    "@vitest/coverage-v8": "4.1.7",
    "chart.js": "^4.5.1",
    "eslint": "10.4.0",
    "npm-run-all2": "9.0.1",
    "playwright": "1.60.0",
    "skia-canvas": "^3.0.8",
    "typedoc": "0.28.19",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "typedocOptions": {
    "entryPoints": [
      "src"
    ],
    "tsconfig": "tsconfig.json",
    "headings": false
  },
  "release": {
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      "@semantic-release/changelog",
      "@semantic-release/npm",
      [
        "@semantic-release/git",
        {
          "assets": [
            "CHANGELOG.md",
            "README.md",
            "package.json",
            "package-lock.json"
          ]
        }
      ],
      "@semantic-release/github"
    ]
  }
}
